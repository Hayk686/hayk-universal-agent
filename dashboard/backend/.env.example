# Copy to .env or set in systemd — do not commit secrets or API keys.
# Backend does not read ~/.hermes/.env.
WORKSPACE_ROOT=/home/ubuntu/ai-office-agent-workspace
HERMES_BIN=hermes
PYTHON_BIN=/home/ubuntu/ai-office-agent-workspace/.venv/bin/python

# Optional: comma-separated browser origins when the UI calls this API from another host/port
# (e.g. Vite dev on a fallback port, or Tailscale IP). Default includes Vite 5173–5175.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5175,http://100.120.203.58:5173

# Optional: if you add API key auth later (not required for MVP).
# DASHBOARD_API_KEY=
