# Copy to .env for local overrides (never commit real secrets).
# API origin: prefer VITE_API_BASE_URL, then VITE_API_BASE, then leave unset to use same-origin + Vite dev proxy (see vite.config.ts).
# Use the server root only, e.g. http://127.0.0.1:8080 — do NOT add a trailing /api (paths like /api/status are appended automatically).
VITE_API_BASE_URL=http://100.120.203.58:8080
VITE_USE_MOCKS=false

# If the UI origin is not allowed by the API, add it to backend CORS_ORIGINS (see dashboard/backend/.env.example).
