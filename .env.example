# Hayk Universal Agent — optional dashboard/runtime variables
# Copy section you need to a local `.env` file (never commit real values).
# The dashboard MVP does not require a `.env` file.

# --- Live workspace on the Pi (dashboard backend default) ---
# WORKSPACE_ROOT=/home/ubuntu/ai-office-agent-workspace

# --- Dashboard API (optional) ---
# DASH_AGENT_NAME=Hayk Universal Agent
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# DASHBOARD_API_KEY=generate-a-long-random-string-if-you-enable-auth

# --- Hermes / LLM keys (set on the Pi in your own secret store, not in this repo) ---
# Do not paste API keys into files tracked by Git.
