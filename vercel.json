{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd dashboard/frontend && npm ci",
  "buildCommand": "cd dashboard/frontend && npm run build",
  "outputDirectory": "dashboard/frontend/dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "agent-workspace/**"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/pc/:path*",
      "destination": "/api/pc-route?path=:path*"
    },
    {
      "source": "/api/pc",
      "destination": "/api/pc-route"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
